---
import Layout from '../layouts/Layout.astro';
import Seo from "../components/Seo.astro";
import articles from "../../public/articles_enriched.json";

const SITE = import.meta.env.PUBLIC_SITE;

const latestArticle = articles?.[0];
const latestArticles = articles?.slice(1, 5);
---

<Layout>
  <Seo
    slot="head"
    title="Inicio | FuturoCientífico"
    description="Plataforma educativa y de divulgación científica gratuita, con contenidos diarios para todas las edades."
    site={SITE}
    ogImage="/whatsapp-futurocientifico.webp"
    alternates={[
      { hreflang: "es", href: "https://futurocientifico.es/" },
    ]}
  />

  <!-- HERO PRINCIPAL -->
  <section class="max-w-5xl mx-auto mb-10" aria-labelledby="titulo-inicio">
    <div class="overflow-hidden rounded-2xl shadow-lg bg-white border border-blue-100">
      <img
        src="/whatsapp-futurocientifico.webp"
        alt="Banner de FuturoCientífico, ciencia fácil para mentes curiosas"
        class="w-full h-auto block"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />

      <div class="text-center px-6 py-8 bg-white">
        <h1 id="titulo-inicio" class="text-3xl md:text-4xl font-bold text-blue-900">
          Bienvenidos a FuturoCientífico
        </h1>

        <p class="mt-4 text-blue-800 text-sm md:text-base max-w-2xl mx-auto leading-relaxed">
          Un proyecto de divulgación y educación científica abierto,
          automatizado y pensado para estudiantes, familias, docentes y mentes curiosas.
        </p>

        <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="/revistas"
            class="inline-block px-6 py-3 bg-blue-700 text-white rounded-full shadow hover:bg-blue-800 focus:outline-none focus:ring-4 focus:ring-blue-300 transition"
          >
            Ver revistas científicas
          </a>

          <a
            href="/eduflash"
            class="inline-block px-6 py-3 bg-yellow-500 text-white rounded-full shadow hover:bg-yellow-600 focus:outline-none focus:ring-4 focus:ring-yellow-300 transition"
          >
            Ver EduFlash
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- INTRODUCCIÓN VISUAL -->
  <section class="max-w-5xl mx-auto mb-12" aria-labelledby="contenido-inicio">
    <div class="bg-white rounded-2xl shadow-sm border border-blue-100 p-6 md:p-8">
      <h2 id="contenido-inicio" class="text-2xl font-bold text-blue-900 text-center">
        Ciencia accesible para mentes curiosas
      </h2>

      <p class="mt-4 text-center text-gray-700 leading-relaxed max-w-3xl mx-auto">
        FuturoCientífico acerca la ciencia a estudiantes, docentes, familias y
        personas curiosas mediante contenidos educativos, noticias científicas,
        recursos y divulgación explicada de forma clara y visual.
      </p>
    </div>
  </section>

  <!-- HOY EN CIENCIA DINÁMICO -->
  <section class="max-w-5xl mx-auto mb-12" aria-labelledby="hoy-ciencia">
    <div class="bg-gradient-to-br from-blue-50 to-cyan-50 border border-blue-100 rounded-2xl p-6 shadow-sm">
      <div class="flex items-center gap-2 mb-5">
        <span class="text-2xl">🔬</span>

        <h2 id="hoy-ciencia" class="text-2xl font-bold text-blue-900">
          Hoy en ciencia
        </h2>
      </div>

      {latestArticle && (
        <article class="space-y-5">
          <div class="flex justify-center">
            <img
              src="/favicon.webp"
              alt="FuturoCientífico"
              class="w-24 h-24 md:w-28 md:h-28 object-contain rounded-2xl shadow-sm bg-white p-2 border border-blue-100"
              loading="lazy"
              decoding="async"
            />
          </div>

          <div class="flex flex-wrap items-center gap-2 text-sm">
            <span class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full font-medium">
              {latestArticle.source}
            </span>

            <span class="text-gray-500">
              {latestArticle.date}
            </span>
          </div>

          <h3 class="text-2xl font-bold text-blue-900 leading-tight">
            {latestArticle.title_es || latestArticle.title}
          </h3>

          <p class="text-gray-700 leading-relaxed">
            Descubre una de las últimas novedades científicas seleccionadas
            automáticamente desde fuentes científicas internacionales.
          </p>

          <div class="flex flex-col sm:flex-row gap-3 pt-2">
            <a
              href={latestArticle.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-full bg-blue-700 text-white hover:bg-blue-800 transition shadow"
            >
              Leer publicación
            </a>

            <a
              href="/revistas"
              class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-full bg-white border border-blue-200 text-blue-900 hover:bg-blue-50 transition shadow-sm"
            >
              Ver más noticias
            </a>
          </div>
        </article>
      )}
    </div>
  </section>

  <!-- ÚLTIMAS PUBLICACIONES -->
  <section class="max-w-6xl mx-auto mb-14" aria-labelledby="ultimas-publicaciones">
    <div class="flex items-center gap-2 mb-6">
      <span class="text-2xl">📰</span>

      <h2 id="ultimas-publicaciones" class="text-2xl font-bold text-blue-900">
        Últimas publicaciones científicas
      </h2>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
      {latestArticles?.map((article) => (
        <article class="bg-white rounded-2xl border border-blue-100 shadow-sm overflow-hidden hover:shadow-md transition">
          <div class="p-5 flex flex-col h-full">
            <div class="flex items-center gap-2 text-xs mb-3">
              <span class="bg-blue-100 text-blue-800 px-2 py-1 rounded-full font-medium">
                {article.source}
              </span>

              <span class="text-gray-500">
                {article.date}
              </span>
            </div>

            <h3 class="text-lg font-bold text-blue-900 leading-snug mb-3 line-clamp-3">
              {article.title_es || article.title}
            </h3>

            <p class="text-sm text-gray-700 leading-relaxed flex-grow">
              Publicación científica seleccionada automáticamente desde fuentes
              internacionales de divulgación e investigación.
            </p>

            <div class="pt-5">
              <a
                href={article.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-blue-700 font-semibold hover:text-blue-900 transition"
              >
                Leer publicación →
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="text-center mt-8">
      <a
        href="/revistas"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-blue-700 text-white hover:bg-blue-800 transition shadow"
      >
        Ver todas las publicaciones
      </a>
    </div>
  </section>
  <!-- NOVA -->
            La ciencia más viral,
            explicada en segundos.
          </h2>

          <p class="mt-5 text-gray-700 leading-relaxed text-base md:text-lg max-w-xl">
            Nova resume descubrimientos científicos, curiosidades y temas virales
            mediante infografías, vídeos cortos y contenido visual pensado para aprender de forma rápida y entretenida.
          </p>

          <!-- BOTONES -->
          <div class="mt-8 flex flex-wrap gap-3 justify-center md:justify-start">

            <a
              href="/nova"
              class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-blue-700 text-white hover:bg-blue-800 transition shadow"
            >
              Explorar Nova
            </a>

            <a
              href="https://instagram.com/futurocientifico2025"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-white border border-blue-200 text-blue-900 hover:bg-blue-50 transition shadow-sm"
            >
              Instagram
            </a>

            <a
              href="https://www.tiktok.com/@futurocientifico"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-white border border-blue-200 text-blue-900 hover:bg-blue-50 transition shadow-sm"
            >
              TikTok
            </a>

            <a
              href="https://www.youtube.com/@FuturoCientifico"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-white border border-blue-200 text-blue-900 hover:bg-blue-50 transition shadow-sm"
            >
              YouTube
            </a>

          </div>

        </div>

        <!-- IMAGEN NOVA -->
        <div class="order-1 md:order-2 flex justify-center">

          <div class="relative">

            <div class="absolute inset-0 bg-cyan-200 blur-3xl opacity-30 rounded-full"></div>

            <img
              src="/nova.webp"
              alt="Nova, avatar científico de FuturoCientífico"
              class="relative w-72 md:w-96 object-contain drop-shadow-xl"
              loading="lazy"
              decoding="async"
            />

          </div>

        </div>

      </div>

    </div>

  </section>
  <!-- TARJETAS VISUALES -->
  <section class="max-w-6xl mx-auto mb-14" aria-labelledby="explorar-secciones">
    <h2 id="explorar-secciones" class="text-2xl font-bold text-blue-900 mb-6 text-center">
      Explora FuturoCientífico
    </h2>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      <a href="/formacion" class="bg-white rounded-2xl border border-blue-100 p-6 shadow-sm hover:shadow-md transition">
        <div class="text-4xl mb-4">🎓</div>
        <h3 class="text-lg font-bold text-blue-900">Formación</h3>
        <p class="mt-2 text-sm text-gray-700">Guías y orientación científica para todas las edades y niveles.</p>
      </a>

      <a href="/recursos" class="bg-white rounded-2xl border border-blue-100 p-6 shadow-sm hover:shadow-md transition">
        <div class="text-4xl mb-4">🧰</div>
        <h3 class="text-lg font-bold text-blue-900">Recursos</h3>
        <p class="mt-2 text-sm text-gray-700">Apps, simuladores, herramientas y materiales educativos.</p>
      </a>

      <a href="/eduflash" class="bg-white rounded-2xl border border-blue-100 p-6 shadow-sm hover:shadow-md transition">
        <div class="text-4xl mb-4">⚡</div>
        <h3 class="text-lg font-bold text-blue-900">EduFlash</h3>
        <p class="mt-2 text-sm text-gray-700">Noticias científicas y educativas resumidas de forma rápida.</p>
      </a>

      <a href="/revistas" class="bg-white rounded-2xl border border-blue-100 p-6 shadow-sm hover:shadow-md transition">
        <div class="text-4xl mb-4">📚</div>
        <h3 class="text-lg font-bold text-blue-900">Revistas</h3>
        <p class="mt-2 text-sm text-gray-700">Publicaciones científicas, investigaciones y novedades.</p>
      </a>

      <a href="/preguntona" class="bg-white rounded-2xl border border-blue-100 p-6 shadow-sm hover:shadow-md transition">
        <div class="text-4xl mb-4">❓</div>
        <h3 class="text-lg font-bold text-blue-900">Preguntona</h3>
        <p class="mt-2 text-sm text-gray-700">Curiosidades, preguntas científicas y explicaciones sencillas.</p>
      </a>

      <a href="/apoya" class="bg-white rounded-2xl border border-blue-100 p-6 shadow-sm hover:shadow-md transition">
        <div class="text-4xl mb-4">💖</div>
        <h3 class="text-lg font-bold text-blue-900">Apóyanos</h3>
        <p class="mt-2 text-sm text-gray-700">Ayuda a mantener este proyecto científico abierto y gratuito.</p>
      </a>
    </div>
  </section>

  <!-- DESCUBRIMIENTO -->
  <section class="max-w-4xl mx-auto mb-14 text-center">
    <div class="bg-gradient-to-r from-purple-100 to-blue-100 rounded-2xl p-8 shadow-sm border border-purple-200">
      <div class="text-5xl mb-4">🎲</div>

      <h2 class="text-2xl font-bold text-blue-900">
        Descubrir algo nuevo
      </h2>

      <p class="mt-3 text-gray-700 max-w-2xl mx-auto">
        Explora preguntas curiosas, revistas científicas y contenidos educativos
        para aprender algo diferente cada día.
      </p>

      <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/preguntona" class="px-6 py-3 rounded-full bg-purple-700 text-white hover:bg-purple-800 transition shadow">
          Ir a Preguntona
        </a>

        <a href="/revistas" class="px-6 py-3 rounded-full bg-blue-700 text-white hover:bg-blue-800 transition shadow">
          Explorar revistas
        </a>
      </div>
    </div>
  </section>

  <!-- ADSENSE -->
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-2163450732409344"
    data-ad-slot="6134548917"
    data-ad-format="auto"
    data-full-width-responsive="true"
  ></ins>

  <script>
    if (typeof window !== "undefined") {
      if (window.adsbygoogle && Array.isArray(window.adsbygoogle)) {
        window.adsbygoogle.push({});
      } else {
        const interval = setInterval(() => {
          if (window.adsbygoogle && Array.isArray(window.adsbygoogle)) {
            window.adsbygoogle.push({});
            clearInterval(interval);
          }
        }, 300);
      }
    }
  </script>
</Layout>
