---
import Layout from "../../layouts/Layout.astro";
import Seo from "../../components/Seo.astro";

const SITE = import.meta.env.PUBLIC_SITE;
---

<Layout>
  <Seo
    slot="head"
    title="Nova | FuturoCientífico"
    description="Nova es el universo futurista de FuturoCientífico donde la inteligencia artificial, el espacio, la robótica y la ciencia avanzada se explican de forma visual y accesible."
    site={SITE}
    canonical="https://futurocientifico.es/nova"
    ogImage="/nova.webp"
    alternates={[
      { hreflang: "es", href: "https://futurocientifico.es/nova" },
    ]}
  />

  <!-- HERO -->
  <section class="max-w-7xl mx-auto mb-16" aria-labelledby="nova-title">
    <div class="relative overflow-hidden rounded-3xl border border-cyan-500/20 bg-gradient-to-br from-slate-950 via-blue-950 to-cyan-950 shadow-2xl">

      <div class="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_top,rgba(0,255,255,0.35),transparent_50%)]"></div>

      <div class="relative grid lg:grid-cols-2 gap-10 items-center p-6 md:p-12">

        <!-- TEXTO -->
        <div class="text-center lg:text-left">

          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-cyan-500/10 border border-cyan-400/20 text-cyan-300 text-sm font-semibold mb-6 backdrop-blur-sm">
            <span>🧠</span>
            <span>Universo Nova</span>
          </div>

          <h1
            id="nova-title"
            class="text-4xl md:text-6xl font-black text-white leading-tight"
          >
            La ciencia del futuro ya está aquí.
          </h1>

          <p class="mt-6 text-cyan-100/90 leading-relaxed text-base md:text-lg max-w-2xl">
            Nova es el universo futurista de FuturoCientífico:
            inteligencia artificial, robótica, espacio, biotecnología y descubrimientos
            científicos explicados de forma visual, moderna y accesible para todos.
          </p>

          <div class="mt-8 flex flex-wrap gap-3 justify-center lg:justify-start">

            <a
              href="https://instagram.com/futurocientifico2025"
              target="_blank"
              rel="noopener noreferrer"
              class="px-5 py-3 rounded-full bg-cyan-500 text-slate-950 font-semibold hover:bg-cyan-400 transition shadow-lg"
            >
              Instagram
            </a>

            <a
              href="https://www.tiktok.com/@futurocientifico"
              target="_blank"
              rel="noopener noreferrer"
              class="px-5 py-3 rounded-full border border-cyan-300/20 bg-white/5 text-cyan-100 hover:bg-white/10 transition backdrop-blur-sm"
            >
              TikTok
            </a>

            <a
              href="https://www.youtube.com/@FuturoCientifico"
              target="_blank"
              rel="noopener noreferrer"
              class="px-5 py-3 rounded-full border border-cyan-300/20 bg-white/5 text-cyan-100 hover:bg-white/10 transition backdrop-blur-sm"
            >
              YouTube
            </a>

            <a
              href="https://x.com/Futuro100tfco"
              target="_blank"
              rel="noopener noreferrer"
              class="px-5 py-3 rounded-full border border-cyan-300/20 bg-white/5 text-cyan-100 hover:bg-white/10 transition backdrop-blur-sm"
            >
              X
            </a>

          </div>
        </div>

        <!-- VIDEO -->
        <div>
          <div class="overflow-hidden rounded-3xl border border-cyan-400/20 bg-black/30 shadow-2xl backdrop-blur-sm">

            <video
              class="w-full h-auto block"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              poster="/nova.webp"
              aria-label="Vídeo de presentación de Nova"
            >
              <source src="/nova-presentacion.mp4" type="video/mp4" />
              Tu navegador no puede reproducir este vídeo.
            </video>

          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CATEGORÍAS -->
  <section class="max-w-7xl mx-auto mb-16" aria-labelledby="nova-categorias">

    <div class="text-center mb-10">
      <h2
        id="nova-categorias"
        class="text-3xl md:text-4xl font-bold text-blue-950"
      >
        Explora el universo Nova
      </h2>

      <p class="mt-4 text-gray-600 max-w-2xl mx-auto">
        Ciencia avanzada, inteligencia artificial y tecnología explicadas
        con un enfoque visual, rápido y accesible.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">

      <article class="rounded-3xl p-6 bg-gradient-to-br from-cyan-500 to-blue-700 text-white shadow-xl">
        <div class="text-5xl mb-4">🧠</div>
        <h3 class="text-2xl font-bold">Inteligencia Artificial</h3>
        <p class="mt-3 text-cyan-50">
          AGI, modelos generativos, IA científica y herramientas que cambiarán el futuro.
        </p>
      </article>

      <article class="rounded-3xl p-6 bg-gradient-to-br from-purple-600 to-indigo-700 text-white shadow-xl">
        <div class="text-5xl mb-4">🚀</div>
        <h3 class="text-2xl font-bold">Espacio y Universo</h3>
        <p class="mt-3 text-purple-50">
          NASA, exoplanetas, telescopios, Marte y nuevas fronteras espaciales.
        </p>
      </article>

      <article class="rounded-3xl p-6 bg-gradient-to-br from-emerald-500 to-teal-700 text-white shadow-xl">
        <div class="text-5xl mb-4">🧬</div>
        <h3 class="text-2xl font-bold">Biotecnología</h3>
        <p class="mt-3 text-emerald-50">
          Medicina del futuro, genética, células inteligentes y ciencia biomédica.
        </p>
      </article>

      <article class="rounded-3xl p-6 bg-gradient-to-br from-orange-500 to-red-600 text-white shadow-xl">
        <div class="text-5xl mb-4">🤖</div>
        <h3 class="text-2xl font-bold">Robótica</h3>
        <p class="mt-3 text-orange-50">
          Robots autónomos, humanoides y automatización avanzada aplicada al mundo real.
        </p>
      </article>

      <article class="rounded-3xl p-6 bg-gradient-to-br from-pink-500 to-fuchsia-700 text-white shadow-xl">
        <div class="text-5xl mb-4">⚛️</div>
        <h3 class="text-2xl font-bold">Física avanzada</h3>
        <p class="mt-3 text-pink-50">
          Computación cuántica, materia oscura y teorías que redefinen el universo.
        </p>
      </article>

      <article class="rounded-3xl p-6 bg-gradient-to-br from-slate-700 to-slate-900 text-white shadow-xl">
        <div class="text-5xl mb-4">🌍</div>
        <h3 class="text-2xl font-bold">Planeta y clima</h3>
        <p class="mt-3 text-slate-100">
          Tecnología climática, biodiversidad y soluciones científicas para el planeta.
        </p>
      </article>

    </div>
  </section>

  <!-- FILOSOFÍA NOVA -->
  <section class="max-w-5xl mx-auto mb-16">
    <div class="rounded-3xl overflow-hidden border border-cyan-100 bg-white shadow-sm p-8 md:p-12 text-center">

      <h2 class="text-3xl md:text-4xl font-bold text-blue-950">
        Ciencia visual para una nueva generación
      </h2>

      <p class="mt-6 text-gray-700 leading-relaxed max-w-3xl mx-auto">
        Nova nace para acercar la ciencia avanzada a cualquier persona,
        utilizando formatos rápidos, visuales y modernos adaptados a móviles,
        redes sociales y nuevas formas de aprender.
      </p>

      <div class="mt-8 flex flex-wrap justify-center gap-3">

        <span class="px-4 py-2 rounded-full bg-cyan-100 text-cyan-800 text-sm font-medium">
          IA
        </span>

        <span class="px-4 py-2 rounded-full bg-purple-100 text-purple-800 text-sm font-medium">
          Espacio
        </span>

        <span class="px-4 py-2 rounded-full bg-pink-100 text-pink-800 text-sm font-medium">
          Futuro
        </span>

        <span class="px-4 py-2 rounded-full bg-emerald-100 text-emerald-800 text-sm font-medium">
          Biotech
        </span>

        <span class="px-4 py-2 rounded-full bg-orange-100 text-orange-800 text-sm font-medium">
          Robótica
        </span>

      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-5xl mx-auto mb-10">
    <div class="rounded-3xl bg-gradient-to-r from-cyan-600 to-blue-700 p-10 text-center text-white shadow-xl">

      <h2 class="text-3xl md:text-4xl font-bold">
        Explora el futuro con Nova
      </h2>

      <p class="mt-4 text-cyan-50 max-w-2xl mx-auto">
        Sigue las publicaciones de Nova y descubre cada día nuevos avances científicos,
        inteligencia artificial y tecnología del futuro.
      </p>

      <div class="mt-8 flex flex-wrap justify-center gap-4">

        <a
          href="/revistas"
          class="px-6 py-3 rounded-full bg-white text-blue-900 font-semibold hover:bg-cyan-50 transition shadow"
        >
          Ver revistas
        </a>

        <a
          href="/"
          class="px-6 py-3 rounded-full border border-white/30 bg-white/10 backdrop-blur-sm hover:bg-white/20 transition"
        >
          Volver a FuturoCientífico
        </a>

      </div>

    </div>
  </section>
</Layout>
