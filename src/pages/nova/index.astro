---
import Layout from "../../layouts/Layout.astro";
import Seo from "../../components/Seo.astro";

const SITE = import.meta.env.PUBLIC_SITE;

const contenidosNova = [
  {
    titulo: "Artemis II: humanos rumbo a la Luna otra vez",
    categoria: "Espacio",
    tipo: "imagen",
    imagen: "/nova/infografias/artemis-ii.webp",
    video: "/nova/videos/artemis-luna.mp4",
  },
  {
    titulo: "Cómo hackear tu memoria usando emociones",
    categoria: "Neurociencia",
    tipo: "imagen",
    imagen: "/nova/infografias/memoria-emociones.webp",
    video: "/nova/videos/memoria-cerebro.mp4",
  },
  {
    titulo: "Tu cerebro elimina recuerdos aburridos",
    categoria: "Neurociencia",
    tipo: "imagen",
    imagen: "/nova/infografias/memoria-aburrida.webp",
  },
  {
    titulo: "Por qué recuerdas mejor cuando eres feliz",
    categoria: "Psicología",
    tipo: "imagen",
    imagen: "/nova/infografias/memoria-feliz.webp",
  },
  {
    titulo: "Música, recuerdos y nostalgia",
    categoria: "Cerebro",
    tipo: "imagen",
    imagen: "/nova/infografias/musica-recuerdos.webp",
  },
  {
    titulo: "Momentos vergonzosos y memoria",
    categoria: "Psicología",
    tipo: "imagen",
    imagen: "/nova/infografias/momentos-vergonzosos.webp",
  },
{
  titulo: "Desde cuándo los mosquitos prefieren humanos",
  categoria: "Biología",
  imagen: "/nova/infografias/mosquitos-humanos.webp",
  video: "/nova/videos/mosquitos-humanos.mp4",
},
{
  titulo: "Microplásticos en el cuerpo humano",
  categoria: "Medio ambiente",
  imagen: "/nova/infografias/microplasticos.webp",
  video: "/nova/videos/microplasticos.mp4",
},
{
  titulo: "El número de Avogadro",
  categoria: "Química",
  imagen: "/nova/infografias/numero-avogadro.webp",
  video: "/nova/videos/numero-avogadro.mp4",
},
{
  titulo: "El número π explicado por Nova",
  categoria: "Matemáticas",
  imagen: "/nova/infografias/numero-pi.webp",
  video: "/nova/videos/numero-pi.mp4",
},
{
  titulo: "La ciencia de las velas",
  categoria: "Química",
  imagen: "/nova/infografias/velas-semana-santa.webp",
  video: "/nova/videos/velas-semana-santa.mp4",
},
{
  titulo: "Presentación de Nova",
  categoria: "Nova",
  imagen: "/nova.webp",
  video: "/nova-presentacion.mp4",
},
];
---

<Layout>
  <Seo
    slot="head"
    title="Nova | FuturoCientífico"
    description="Nova es el universo visual de FuturoCientífico: vídeos, infografías y ciencia moderna explicada de forma clara, atractiva y accesible."
    site={SITE}
    canonical="https://futurocientifico.es/nova"
    ogImage="/nova.webp"
    alternates={[
      { hreflang: "es", href: "https://futurocientifico.es/nova" },
    ]}
  />

  <section class="max-w-7xl mx-auto mb-16" aria-labelledby="nova-title">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-slate-950 via-blue-950 to-cyan-950 border border-cyan-500/20 shadow-2xl">
      <div class="relative grid lg:grid-cols-2 gap-10 items-center p-8 md:p-14">
        <div class="text-center lg:text-left">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-cyan-500/10 border border-cyan-400/20 text-cyan-300 text-sm font-semibold mb-6">
            🧠 Universo Nova
          </div>

          <h1 id="nova-title" class="text-4xl md:text-6xl font-black text-white leading-tight">
            Ciencia visual para mentes curiosas.
          </h1>

          <p class="mt-6 text-cyan-100/90 text-lg leading-relaxed">
            Vídeos, infografías y contenido visual sobre neurociencia, espacio,
            química, biología y ciencia moderna explicado de forma clara y espectacular.
          </p>

          <div class="mt-8 flex flex-wrap gap-4 justify-center lg:justify-start">
            <a href="#contenido-nova" class="px-6 py-3 rounded-full bg-cyan-400 text-slate-950 font-bold hover:bg-cyan-300 transition shadow-lg">
              Explorar Nova
            </a>

            <a href="/revistas" class="px-6 py-3 rounded-full border border-cyan-300/20 bg-white/10 text-cyan-100 hover:bg-white/20 transition">
              Revistas científicas
            </a>
          </div>
        </div>

        <div class="relative group overflow-hidden rounded-3xl border border-cyan-500/20 shadow-2xl bg-black aspect-video">
          <img
            src="/nova.webp"
            alt="Nova, universo visual de FuturoCientífico"
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition duration-500"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />

          <div class="absolute inset-0 bg-black/20 group-hover:bg-black/35 transition"></div>

          <div class="absolute inset-0 flex items-center justify-center p-4">
            <button
              type="button"
              class="video-open px-7 py-4 rounded-full bg-cyan-400 text-slate-950 font-black text-base md:text-lg shadow-2xl hover:bg-cyan-300 transition"
              data-video="/nova-presentacion.mp4"
            >
              ▶ Ver presentación
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="contenido-nova" class="max-w-7xl mx-auto mb-20">
    <div class="mb-8">
      <h2 class="text-3xl md:text-4xl font-bold text-blue-950">
        🚀 Contenido Nova
      </h2>

      <p class="mt-3 text-gray-600">
        Infografías y vídeos científicos optimizados para aprender de forma visual.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-3">
      {contenidosNova.map((item) => (
        <article class="group overflow-hidden rounded-3xl bg-slate-950 border border-cyan-500/10 shadow-xl hover:shadow-cyan-500/20 transition">
          <div class="relative overflow-hidden bg-black">
            {item.tipo === "video" ? (
              <video
                src={item.video}
                class="w-full aspect-[4/5] object-cover"
                controls
                preload="metadata"
                playsinline
              ></video>
            ) : (
              <img
                src={item.imagen}
                alt={item.titulo}
                class="w-full aspect-[4/5] object-cover group-hover:scale-105 transition duration-500"
                loading="lazy"
                decoding="async"
              />
            )}

            <span class="absolute top-4 left-4 px-3 py-1 rounded-full bg-cyan-400 text-slate-950 text-xs font-bold shadow">
              {item.categoria}
            </span>

            {item.tipo !== "video" && item.video && (
              <button
                type="button"
                class="video-open absolute inset-0 m-auto h-fit w-fit px-6 py-3 rounded-full bg-white/95 text-slate-950 font-bold shadow-xl opacity-0 group-hover:opacity-100 transition"
                data-video={item.video}
              >
                ▶ Ver vídeo
              </button>
            )}
          </div>

          <div class="p-6">
            <h3 class="text-xl font-bold text-white leading-snug">
              {item.titulo}
            </h3>

            <div class="mt-5 flex items-center justify-between gap-4">
              {item.imagen ? (
                <a
                  href={item.imagen}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-cyan-300 hover:text-cyan-200 font-medium text-sm"
                >
                  Ver infografía
                </a>
              ) : (
                <span class="text-cyan-300 font-medium text-sm">
                  Vídeo Nova
                </span>
              )}

              {item.video ? (
                <button
                  type="button"
                  class="video-open text-white text-sm font-semibold hover:text-cyan-300 transition"
                  data-video={item.video}
                >
                  Abrir vídeo →
                </button>
              ) : (
                <span class="text-slate-400 text-sm">Infografía</span>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="max-w-6xl mx-auto mb-20">
    <div class="rounded-3xl bg-gradient-to-br from-slate-950 via-blue-950 to-cyan-950 border border-cyan-500/20 shadow-2xl p-8 md:p-12">
      <div class="text-center mb-10">
        <h2 class="text-3xl md:text-4xl font-bold text-white">
          🌐 Sigue Nova en redes
        </h2>

        <p class="mt-4 text-cyan-100/90 max-w-2xl mx-auto">
          Vídeos científicos, infografías visuales y contenido diario de FuturoCientífico.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        <a href="https://instagram.com/futurocientifico2025" target="_blank" rel="noopener noreferrer" class="rounded-3xl bg-gradient-to-br from-pink-500 to-purple-700 p-6 text-white shadow-xl hover:scale-105 transition">
          <div class="text-5xl mb-4">📸</div>
          <h3 class="text-2xl font-bold">Instagram</h3>
          <p class="mt-3 text-pink-100">Infografías científicas y publicaciones visuales.</p>
          <div class="mt-6 font-semibold">Abrir →</div>
        </a>

        <a href="https://www.tiktok.com/@futurocientifico" target="_blank" rel="noopener noreferrer" class="rounded-3xl bg-gradient-to-br from-slate-900 to-black p-6 text-white shadow-xl hover:scale-105 transition border border-white/10">
          <div class="text-5xl mb-4">🎵</div>
          <h3 class="text-2xl font-bold">TikTok</h3>
          <p class="mt-3 text-slate-300">Vídeos rápidos de ciencia y curiosidades.</p>
          <div class="mt-6 font-semibold">Abrir →</div>
        </a>

        <a href="https://www.youtube.com/@FuturoCientifico" target="_blank" rel="noopener noreferrer" class="rounded-3xl bg-gradient-to-br from-red-600 to-red-800 p-6 text-white shadow-xl hover:scale-105 transition">
          <div class="text-5xl mb-4">▶️</div>
          <h3 class="text-2xl font-bold">YouTube</h3>
          <p class="mt-3 text-red-100">Vídeos largos y contenido educativo.</p>
          <div class="mt-6 font-semibold">Abrir →</div>
        </a>

        <a href="https://x.com/Futuro100tfco" target="_blank" rel="noopener noreferrer" class="rounded-3xl bg-gradient-to-br from-cyan-600 to-blue-700 p-6 text-white shadow-xl hover:scale-105 transition">
          <div class="text-5xl mb-4">⚡</div>
          <h3 class="text-2xl font-bold">X / Twitter</h3>
          <p class="mt-3 text-cyan-100">Noticias científicas y avances tecnológicos.</p>
          <div class="mt-6 font-semibold">Abrir →</div>
        </a>
      </div>
    </div>
  </section>

  <div id="video-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 p-4">
    <div class="relative w-full max-w-4xl rounded-2xl bg-slate-950 border border-cyan-500/20 shadow-2xl overflow-hidden">
      <button
        type="button"
        id="video-close"
        class="absolute right-3 top-3 z-10 rounded-full bg-white text-slate-950 px-3 py-1 font-bold"
        aria-label="Cerrar vídeo"
      >
        ✕
      </button>

      <video id="video-player" class="w-full max-h-[80vh] bg-black" controls playsinline>
        <source id="video-source" src="" type="video/mp4" />
        Tu navegador no puede reproducir este vídeo.
      </video>
    </div>
  </div>

  <script>
    const modal = document.querySelector("#video-modal");
    const player = document.querySelector("#video-player");
    const source = document.querySelector("#video-source");
    const close = document.querySelector("#video-close");

    document.querySelectorAll(".video-open").forEach((button) => {
      button.addEventListener("click", () => {
        const video = button.getAttribute("data-video");
        if (!video || !modal || !player || !source) return;

        source.setAttribute("src", video);
        player.load();
        modal.classList.remove("hidden");
        modal.classList.add("flex");
        player.play();
      });
    });

    function closeVideo() {
      if (!modal || !player || !source) return;

      player.pause();
      source.setAttribute("src", "");
      player.load();
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    }

    close?.addEventListener("click", closeVideo);

    modal?.addEventListener("click", (event) => {
      if (event.target === modal) closeVideo();
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeVideo();
    });
  </script>
</Layout>
